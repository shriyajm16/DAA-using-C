#include <stdio.h>
#include <stdlib.h>

int count=0;

void selectionsort(int a[10],int n)
{

    int i,j,min,temp;
    for(i=0;i<=n-2;i++)
        {
            min=i;
        for(j=i+1;j<=n-1;j++)
        {

            count=count+1;
            if(a[j]<a[min])
                min=j;
        }
        temp=a[i];
        a[i]=a[min];
        a[min]=temp;
        }
}

int main()
{

    int n,i,a[10];
    printf("\n read array size:\n");
    scanf("%d",&n);
    printf("\n Read array elements:\n");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);


selectionsort(a,n);
printf("\n sorted elements are: \n");
for(i=0;i<n;i++)
    printf("%d\t",a[i]);
    printf("\n total number of comparision =%d",count);
    return 0;

}
